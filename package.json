{
  "name": "@sanbaiw/web-source-bundler",
  "version": "0.1.0",
  "description": "Fetch, preserve, and bundle web sources into Markdown entries with local references and assets.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanbaiw/web-source-bundler.git"
  },
  "bugs": {
    "url": "https://github.com/sanbaiw/web-source-bundler/issues"
  },
  "homepage": "https://github.com/sanbaiw/web-source-bundler#readme",
  "packageManager": "bun@1.3.14",
  "bin": {
    "web-source-bundler": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/cli.mjs --target=node --outfile=dist/cli.js --external sharp && chmod +x dist/cli.js",
    "dev": "bun ./src/cli.mjs",
    "test": "bun run build && bun ./test/preserved-source-ingest.test.mjs",
    "pack:check": "bun run test && bun pm pack --dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "sharp": "^0.33.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
